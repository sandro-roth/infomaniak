Unattended-Upgrade::Automatic-Reboot "{{ security_autoupdate_reboot | default('false') }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ security_autoupdate_reboot_time | default('02:00') }}";

{% if security_autoupdate_mail_to | default('') %}
Unattended-Upgrade::Mail "{{ security_autoupdate_mail_to }}";
{% if security_autoupdate_mail_on_error | default(false) %}
Unattended-Upgrade::MailOnlyOnError "true";
{% endif %}
{% endif %}

Unattended-Upgrade::Allowed-Origins {
        "${distro_id}:${distro_codename}-security";
//      "${distro_id}:${distro_codename}-updates";
};

Unattended-Upgrade::Package-Blacklist {
{% for package in security_autoupdate_blacklist | default([]) %}
        "{{ package }}";
{% endfor %}
}; 