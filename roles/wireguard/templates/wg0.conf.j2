[Interface]
PrivateKey = {{ wireguard_private_key_slurp.content | b64decode | trim }}
{% if wireguard_role == "server" %}
Address = {{ wireguard_server_address }}
ListenPort = {{ wireguard_port }}
{% else %}
Address = {{ wireguard_client_address }}
{% endif %}

{% if wireguard_role == "server" %}
{% for peer in wireguard_peers %}
[Peer]
PublicKey = {{ peer.public_key }}
AllowedIPs = {{ peer.allowed_ips | join(', ') }}

{% endfor %}
{% else %}
[Peer]
PublicKey = {{ wireguard_server_public_key }}
Endpoint = {{ wireguard_endpoint }}
AllowedIPs = {{ wireguard_allowed_ips | join(', ') }}
PersistentKeepalive = {{ wireguard_persistent_keepalive }}
{% endif %}