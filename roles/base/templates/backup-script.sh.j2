#!/bin/bash
set -e

BACKUP_DIR="{{ backup_dir }}"
DATE=$(date +%F-%H-%M)

mkdir -p "$BACKUP_DIR"

tar -czf "$BACKUP_DIR/etc-$DATE.tar.gz" /etc
tar -czf "$BACKUP_DIR/home-$DATE.tar.gz" /home
tar -czf "$BACKUP_DIR/www-$DATE.tar.gz" /var/www 2>/dev/null || true

dpkg --get-selections > "$BACKUP_DIR/packages-$DATE.txt"

# Keep only latest 2 backups
ls -1t "$BACKUP_DIR"/*.tar.gz | tail -n +3 | xargs -r rm -f
ls -1t "$BACKUP_DIR"/packages-*.txt | tail -n +3 | xargs -r rm -f